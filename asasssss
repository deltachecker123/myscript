    function library:InitConfig(section)
        local autoloadFile = folder .. "//autoload.json"
        local configName   = ""
        local nameInput
        local configDropdown

        -- Read autoload file to pre-select the saved config
        local autoloadData = nil
        if isfile(autoloadFile) then
            local ok, parsed = pcall(function()
                return services.HttpService:JSONDecode(readfile(autoloadFile))
            end)
            if ok and parsed then
                autoloadData = parsed
                configName   = parsed.config or ""
            end
        end

        -- Helper: returns current list of saved configs
        local function getConfigList()
            local ok, list = pcall(library.ListConfigs, library)
            return (ok and list) and list or {}
        end

        -- Helper: refreshes the dropdown after a save or delete
        local function refreshDropdown()
            if configDropdown then
                configDropdown:Refresh(getConfigList())
            end
        end

        -- Config List Dropdown (replaces the old static Config Name textbox)
        local initialList = getConfigList()
        configDropdown = section:Dropdown({
            name    = "Config List",
            options = initialList,
            default = (configName ~= "" and table.find(initialList, configName)) and configName or nil,
            callback = function(selected)
                configName = selected or ""
                if nameInput then
                    nameInput:Set(configName)
                end
            end
        })

        -- Textbox so you can still type a brand-new name before saving
        nameInput = section:Textbox({
            name        = "Config Name",
            default     = configName,
            placeholder = "type a name to save...",
            callback    = function(text)
                configName = text:gsub("%s+", ""):lower()
            end
        })

        section:Button({
            name = "Save Config",
            callback = function()
                if configName == "" then return end
                pcall(library.SaveConfig, library, configName)
                refreshDropdown()  -- update the list after saving
            end
        })

        section:Button({
            name = "Load Config",
            callback = function()
                if configName == "" then return end
                pcall(library.LoadConfig, library, configName)
            end
        })

        section:Button({
            name = "Delete Config",
            callback = function()
                if configName == "" then return end
                pcall(library.DeleteConfig, library, configName)
                -- clear autoload if it pointed at this config
                if isfile(autoloadFile) then
                    local ok, d = pcall(function()
                        return services.HttpService:JSONDecode(readfile(autoloadFile))
                    end)
                    if ok and d and d.config == configName then
                        pcall(delfile, autoloadFile)
                    end
                end
                configName = ""
                if nameInput then nameInput:Set("") end
                refreshDropdown()  -- update the list after deleting
            end
        })

        -- Auto Load Config button (replaces the old Autoload toggle)
        section:Button({
            name = "Set as Auto Load",
            callback = function()
                if configName == "" then return end
                pcall(writefile, autoloadFile,
                    services.HttpService:JSONEncode({ enabled = true, config = configName })
                )
            end
        })

        section:Button({
            name = "Clear Auto Load",
            callback = function()
                if isfile(autoloadFile) then pcall(delfile, autoloadFile) end
            end
        })

        -- Actually trigger the auto-load on startup (original code only pre-filled UI, never loaded)
        if autoloadData and autoloadData.enabled == true and (autoloadData.config or "") ~= "" then
            task.defer(function()
                task.wait(0.5)
                local ok, err = pcall(library.LoadConfig, library, autoloadData.config)
                warn("[AUTOLOAD] Loaded " .. autoloadData.config .. " ok=" .. tostring(ok) .. " err=" .. tostring(err))
            end)
        else
            warn("[AUTOLOAD] Skipped: enabled=" .. tostring(autoloadData and autoloadData.enabled) .. " config=" .. tostring(autoloadData and autoloadData.config))
        end
    end

