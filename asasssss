secSettings:Toggle({ 
    name = "FPS Boost", 
    default = false, 
    pointer = "ptr_fpsBoost",
    callback = function(v) 
        S.fpsBoost = v
        
        local success, err = pcall(function()
            if v then
                -- ==========================================
                -- TURN ON: Save original states and disable
                -- ==========================================
                
                -- Cache Lighting Settings
                if lightingCache.GlobalShadows == nil then
                    lightingCache.GlobalShadows = Lighting.GlobalShadows
                    lightingCache.FogEnd = Lighting.FogEnd
                    pcall(function() lightingCache.QualityLevel = settings().Rendering.QualityLevel end)
                    
                    pcall(function() lightingCache.Technology = Lighting.Technology end)
                end
                
                -- Apply Lighting Changes
                Lighting.GlobalShadows = false
                Lighting.FogEnd = 1e6
                pcall(function() settings().Rendering.QualityLevel = 1 end)
                
                pcall(function() Lighting.Technology = Enum.Technology.Voxel end)

                -- Process Lighting Children
                for _, e in ipairs(Lighting:GetChildren()) do
                    if e:IsA("BloomEffect") or e:IsA("SunRaysEffect") or e:IsA("DepthOfFieldEffect") or e:IsA("BlurEffect") or e:IsA("PostEffect") then 
                        if cache[e] == nil then cache[e] = e.Enabled end
                        e.Enabled = false 
                    end
                end
                
                -- Process Workspace (Asynchronous)
                task.spawn(function()
                    for _, d in ipairs(Workspace:GetDescendants()) do
                        if S.fpsBoost == false then break end -- Stop if they toggle off mid-loop
                        
                        pcall(function()
                            if d:IsA("ParticleEmitter") or d:IsA("Trail") or d:IsA("Smoke") or d:IsA("Fire") or d:IsA("Sparkles") then 
                                if cache[d] == nil then cache[d] = d.Enabled end
                                d.Enabled = false
                            elseif d:IsA("Texture") or d:IsA("Decal") then 
                                if cache[d] == nil then cache[d] = d.Transparency end
                                d.Transparency = 1 
                            end
                        end)
                    end
                end)
                
            else
                -- ==========================================
                -- TURN OFF: Restore original states
                -- ==========================================
                
                -- Restore Lighting Settings
                if lightingCache.GlobalShadows ~= nil then
                    Lighting.GlobalShadows = lightingCache.GlobalShadows
                    Lighting.FogEnd = lightingCache.FogEnd
                    pcall(function() settings().Rendering.QualityLevel = lightingCache.QualityLevel or Enum.QualityLevel.Automatic end)
                end
                
                if lightingCache.Technology then
                    pcall(function() Lighting.Technology = lightingCache.Technology end)
                end
                
                -- Restore Workspace and Lighting Children from cache (Asynchronous)
                task.spawn(function()
                    for obj, originalValue in pairs(cache) do
                        pcall(function()
                            if obj:IsA("Texture") or obj:IsA("Decal") then
                                obj.Transparency = originalValue
                            else
                                obj.Enabled = originalValue
                            end
                        end)
                    end
                    
                    -- Reset the cache completely so fresh data is gathered next time it's turned on
                    cache = setmetatable({}, {__mode = "k"})
                end)
            end
        end)

        if not success then
            warn("FPS Boost Error: " .. tostring(err))
        end
    end 
})

-- World cleanup: auto-nuke other players' plants for FPS
local userIdWC = LocalPlayer.UserId
local watchersWC = {}

local function destroyPlotPlants(plot)
    local c = plot:FindFirstChild("Plants")
    if c then
        for _, obj in ipairs(c:GetChildren()) do obj:Destroy() end
    end
end

local function nukeWC()
    local gardens = Workspace:FindFirstChild("Gardens")
    if not gardens then return end
    for _, plot in ipairs(gardens:GetChildren()) do
        local ownerId = plot:GetAttribute("OwnerUserId")
        if ownerId == nil or ownerId ~= userIdWC then
            destroyPlotPlants(plot)
        end
    end
end

local function stopWatchersWC()
    for _, c in ipairs(watchersWC) do c:Disconnect() end
    table.clear(watchersWC)
end

local function startWatchersWC()
    stopWatchersWC()
    local gardens = Workspace:FindFirstChild("Gardens")
    if not gardens then return end
    local function hook(c)
        if not c then return end
        local conn = c.ChildAdded:Connect(function(child)
            task.wait(); nukeWC()
        end)
        table.insert(watchersWC, conn)
    end
    for _, plot in ipairs(gardens:GetChildren()) do
        local ownerId = plot:GetAttribute("OwnerUserId")
        if ownerId == nil or ownerId ~= userIdWC then
            hook(plot:FindFirstChild("Plants"))
        end
    end
    local conn = gardens.ChildAdded:Connect(function() task.wait(0.5); nukeWC() end)
    table.insert(watchersWC, conn)
end

