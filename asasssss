local LAST_COLLECT_TIME = 0
loopOn(function() return S.autoEventSeeds end, 0.6, function()
    local map = Workspace:FindFirstChild("Map")
    if not map then return end

    local function getSeedPackName(obj)
        if not obj or not obj.Parent then return nil end
        local rainbow = obj:GetAttribute("RainbowSeed")
        if rainbow == true or rainbow == "true" then return "Rainbow" end
        local gold = obj:GetAttribute("GoldSeed")
        if gold == true or gold == "true" then return "Gold" end
        local spAttr = obj:GetAttribute("SeedPack")
        if spAttr and spAttr ~= "" then return spAttr end
        return nil
    end

    local seeded = {}
    local serverLocs = map:FindFirstChild("SeedPackSpawnServerLocations")
    if serverLocs then
        for _, obj in ipairs(serverLocs:GetChildren()) do
            if not S.autoEventSeeds then return end
            if not obj.Parent then continue end
            local name = getSeedPackName(obj)
            if not name then name = obj.Name end
            local pos
            pcall(function() pos = obj:IsA("BasePart") and obj.Position or (obj:GetPivot().Position) end)
            if pos then
                table.insert(seeded, {obj = obj, name = name, pos = pos})
            end
        end
    end

    local clientLocs = map:FindFirstChild("SeedPackSpawnClient")
    if clientLocs then
        for _, obj in ipairs(clientLocs:GetChildren()) do
            if not S.autoEventSeeds then return end
            if not obj.Parent then continue end
            local name = getSeedPackName(obj) or obj.Name
            local base = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart", true)
            if base and base.Parent then
                table.insert(seeded, {obj = obj, name = name, pos = base.Position})
            end
        end
    end

    if #seeded == 0 then return end

    local savedCF
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

    for _, t in ipairs(seeded) do
        if not S.autoEventSeeds then return end
        if not t.obj.Parent then continue end
        
        flingNearbyDuringTask()

        if not hrp or not hrp.Parent then
            hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then break end
        end

        if not savedCF then savedCF = hrp.CFrame end

        pcall(function()
            hrp.CFrame = CFrame.new(t.pos + Vector3.new(0, 3, 0))
            hrp.Velocity = Vector3.new(0, 0, 0)
        end)
        task.wait(0.1)

        -- Try ClickPack + Claimed with the derived name
        pcall(function() fire("SeedPack.ClickPack", t.name) end)
        pcall(function() fireFast("SeedPackSpawn.Claimed", LocalPlayer.Name, t.name) end)
        task.wait(0.05)

        -- Also fire proximity prompt as backup (for server-side proximity checks)
        local base = t.obj:IsA("BasePart") and t.obj or t.obj:FindFirstChildWhichIsA("BasePart", true)
        if base then
            local prompt = t.obj:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then fireproximityprompt(prompt) end
            local touch = t.obj:FindFirstChildWhichIsA("TouchTransmitter", true)
            if touch and firetouchinterest and hrp then
                firetouchinterest(hrp, base, 0)
                task.wait(0.05)
                firetouchinterest(hrp, base, 1)
            end
        end
        task.wait(0.1)
    end

    if savedCF and hrp and hrp.Parent then
        pcall(function() hrp.CFrame = savedCF end)
    end
end)

