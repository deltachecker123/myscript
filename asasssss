local blacklistedPets = {} 
local lastTameTime = 0 -- Tracks the exact moment we finished taming

task.spawn(function()
    while true do 
        if S.autoBuyPets then
            for _, w in ipairs(wildPets()) do
                if not S.autoBuyPets then break end
                
                -- Cooldown check. Wait 1.5 seconds after a previous tame before targeting anything else.
                -- This stops the script from targeting the newly spawned "owned" version of the pet.
                if os.clock() - lastTameTime < 1.5 then continue end
                
                if blacklistedPets[w.part] then continue end
                
                -- Check Multibox Logic
                local shouldBuy = false
                if S.buyAllWildPets then
                    shouldBuy = true
                elseif S.buyWildPets then
                    if S.buyWildPets[w.name] == true then
                        shouldBuy = true
                    elseif type(S.buyWildPets) == "table" and table.find(S.buyWildPets, w.name) then
                        shouldBuy = true
                    end
                end
                
                -- Read the exact OwnerUserId directly from the part, skipping any lag from the wildPets() function
                local realOwnerId = (w.part and w.part.Parent and w.part:GetAttribute("OwnerUserId")) or 0

                if shouldBuy and w.part and w.part.Parent and realOwnerId == 0 and w.price > 0 and w.price <= S.maxPetPrice and getSheckles() >= w.price then
                    
                    blacklistedPets[w.part] = true
                    
                    local hrp = getFreshHRP()
                    local savedCFrame = hrp and hrp.CFrame
                    
                    local t0 = os.clock()
                    
                    while S.autoBuyPets and w.part and w.part.Parent and os.clock() - t0 < 60 do
                        
                        flingNearbyDuringTask()

                        local currentOwnerId = w.part:GetAttribute("OwnerUserId") or 0
                        if currentOwnerId ~= 0 then
                            break
                        end

                        local currentHrp = getFreshHRP()
                        if S.petTeleport and currentHrp then
                            pcall(function()
                                currentHrp.CFrame = CFrame.new(w.part.Position + Vector3.new(0, 3, 2))
                                currentHrp.Velocity = Vector3.new(0, 0, 0) 
                            end)
                        end
                        
                        pcall(function() fire("Pets.WildPetTame", w.part) end)
                        
                        task.wait(0.1)
                    end
                    
                    task.wait(0.2) 
                    
                    -- GO BACK TO ORIGINAL SPOT (re-asserted over several frames so it sticks)
                    if S.petTeleport and savedCFrame then
                        for i = 1, 5 do
                            local finalHrp = getFreshHRP()
                            if not finalHrp then break end
                            pcall(function()
                                finalHrp.CFrame = savedCFrame
                                finalHrp.Velocity = Vector3.new(0, 0, 0)
                                finalHrp.RotVelocity = Vector3.new(0, 0, 0)
                            end)
                            task.wait(0.05)
                        end
                    end
                    
                    if Stats and Stats.tamed then
                        Stats.tamed += 1
                    end
                    
                    -- Start the cooldown timer the moment we get back
                    lastTameTime = os.clock()
                    print("[DEBUG] Cooldown started at", lastTameTime, "for part", w.part)
                    
                    break -- stop here, don't chase the next wild pet in this same pass
                end
            end
        end
        task.wait(0.5)
        
        for part, _ in pairs(blacklistedPets) do
            if not part or not part.Parent then
                blacklistedPets[part] = nil
            end
        end
    end
end)

